# SentryMail Environment Configuration

# IMAP Configuration for Live Mailbox Monitoring
# Set EMAIL_USER and EMAIL_PASSWORD to enable automatic background monitoring on app startup.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your_email@gmail.com
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_app_password
IMAP_MAILBOX=INBOX
POLL_INTERVAL_SECONDS=10

# Secret Key for Flask Session/App
FLASK_SECRET_KEY=sentrymail_super_secret_key_2026
